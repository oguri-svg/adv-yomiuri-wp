{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "cwc/wrapper-white",
  "version": "0.1.0",
  "category": "cwc-blocks",
  "attributes": {
    "innerBlocks_length": {
      "type": "number",
      "default": 0
    }
  },
  "supports": {
    "html": false,
    "className": true,
    "customClassName": false,
    "anchor": true,
    "background": {
      "backgroundImage": true,
      "backgroundSize": true
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css"
}