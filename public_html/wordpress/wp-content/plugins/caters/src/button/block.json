{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 2,
	"name": "cwc/button",
	"version": "0.1.0",
	"category": "cwc-blocks",
	"attributes": {
		"text": {
			"type": "string",
			"default": ""
		},
		"align": {
			"type": "string",
			"default": "center"
		},
		"url": {
			"type": "string",
			"default": ""
		},
		"target": {
			"type": "string",
			"default": "_self"
		}
	},
	"supports": {
		"html": false,
		"className": true,
		"customClassName": false,
		"anchor": false,
		"background": {
			"backgroundImage": true,
			"backgroundSize": true
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css"
}