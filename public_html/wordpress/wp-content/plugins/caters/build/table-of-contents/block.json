{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "cwc/table-of-contents",
  "version": "0.1.0",
  "category": "cwc-blocks",
  "attributes": {
    "items": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "level": {
            "type": "number"
          }
        }
      }
    }
  },
  "supports": {
    "html": false,
    "className": true,
    "customClassName": false
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css"
}