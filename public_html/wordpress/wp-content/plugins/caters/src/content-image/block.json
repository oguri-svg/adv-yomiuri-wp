{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 2,
	"name": "cwc/content-image",
	"version": "0.1.0",
	"category": "cwc-blocks",
	"attributes": {
		"src": {
			"type": "string",
			"default": ""
		},
		"alt": {
			"type": "string",
			"default": ""
		},
		"caption": {
			"type": "string",
			"default": ""
		},
		"captionAlign": {
			"type": "string",
			"default": "center"
		},
		"content":{
			"type":"string",
			"default":""
		},
		"imagePostion":{
			"type":"string",
			"default":"left"
		}
	},
	"supports": {
		"html": false,
		"className": true,
		"customClassName": false,
		"anchor": false,
		"background": {
			"backgroundImage": true,
			"backgroundSize": true
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css"
}